---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="app">
    <header>
      <h1>HTML Reducer</h1>
      <span class="privacy-note">your HTML never leaves your browser</span>
    </header>

    <div class="workspace">
      <!-- Controls -->
      <aside class="controls">
        <button class="controls-toggle" id="controls-toggle" aria-expanded="false">
          options
          <svg viewBox="0 0 16 16"><path d="M4 6l4 4 4-4"></path></svg>
        </button>

        <div class="controls-body collapsed" id="controls-body">
          <div class="control-section">
            <div class="section-label">strip</div>
            <div class="toggle-list">
              <label class="toggle-row">
                <span class="toggle-label">scripts</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripScripts" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">styles</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripStyles" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">comments</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripComments" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">meta / link / head</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripMetaLinkHead" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">hidden elements</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripHidden" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">svg</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripSvg" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">noscript</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripNoscript" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">event handlers</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripEventHandlers" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
            </div>
          </div>

          <div class="control-section">
            <div class="section-label">attributes</div>
            <div class="toggle-list">
              <label class="toggle-row" data-attr-sub>
                <span class="toggle-label">strip id / class</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripIdClass" />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row" data-attr-sub>
                <span class="toggle-label">strip href</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripHref" />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row" data-attr-sub>
                <span class="toggle-label">strip src / alt</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripSrcAlt" />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">strip all attrs</span>
                <span class="toggle">
                  <input type="checkbox" data-key="stripAllAttrs" />
                  <span class="toggle-track"></span>
                </span>
              </label>
            </div>
          </div>

          <div class="control-section">
            <div class="section-label">structure</div>
            <div class="toggle-list">
              <label class="toggle-row">
                <span class="toggle-label">collapse whitespace</span>
                <span class="toggle">
                  <input type="checkbox" data-key="collapseWhitespace" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
              <label class="toggle-row">
                <span class="toggle-label">remove empty tags</span>
                <span class="toggle">
                  <input type="checkbox" data-key="removeEmptyTags" checked />
                  <span class="toggle-track"></span>
                </span>
              </label>
            </div>
          </div>

          <button class="reset-btn" id="btn-reset">reset to defaults</button>
        </div>

        <div class="attribution">
          <a
            href="https://mohamedyamani.com?utm_source=html-reducer"
            target="_blank"
            rel="noopener noreferrer"
          >Built by Mohamed Yamani</a>
          <span>·</span>
          <a
            href="https://github.com/yamanidev/html-reducer"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub repository"
          >
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
        </div>
      </aside>

      <!-- Input panel -->
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">input</span>
          <div class="panel-meta">
            <span id="input-chars">0 chars</span>
            <button class="icon-btn" id="btn-clear">
              <svg viewBox="0 0 16 16">
                <path d="M12 4L4 12M4 4l8 8"></path>
              </svg>
              clear
            </button>
          </div>
        </div>
        <textarea id="html-input" placeholder="paste html here…" spellcheck="false"></textarea>
      </div>

      <!-- Output panel -->
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">output</span>
          <div class="panel-meta">
            <span class="reduction-badge" id="reduction-badge" style="display:none">−0%</span>
            <span class="token-count">
              <span id="token-count">~0 tokens</span>
              <span class="tooltip-anchor">
                <svg viewBox="0 0 16 16">
                  <circle cx="8" cy="8" r="6"></circle>
                  <path d="M8 7.5v3M8 5v.5"></path>
                </svg>
                <span class="tooltip">estimated — 1 token ≈ 4 chars</span>
              </span>
            </span>
            <button class="icon-btn" id="btn-copy">
              <svg viewBox="0 0 16 16">
                <rect x="5" y="5" width="8" height="8" rx="1"></rect>
                <path d="M3 11V3h8"></path>
              </svg>
              copy
            </button>
          </div>
        </div>
        <div class="output-area" id="html-output"></div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { reduceHtml, DEFAULT_CONFIG } from "../lib/reducer";
  import type { ReducerConfiguration } from "../lib/reducer";

  const inputEl = document.getElementById("html-input") as HTMLTextAreaElement;
  const outputEl = document.getElementById("html-output") as HTMLElement;
  const inputCharsEl = document.getElementById("input-chars") as HTMLElement;
  const tokenCountEl = document.getElementById("token-count") as HTMLElement;
  const reductionEl = document.getElementById("reduction-badge") as HTMLElement;
  const clearBtn = document.getElementById("btn-clear") as HTMLButtonElement;
  const copyBtn = document.getElementById("btn-copy") as HTMLButtonElement;
  const resetBtn = document.getElementById("btn-reset") as HTMLButtonElement;
  const controlsToggle = document.getElementById("controls-toggle") as HTMLButtonElement;
  const controlsBody = document.getElementById("controls-body") as HTMLElement;
  const toggleInputs = document.querySelectorAll<HTMLInputElement>("input[data-key]");
  const stripAllInput = document.querySelector<HTMLInputElement>(
    'input[data-key="stripAllAttrs"]',
  )!;
  const attrKeepRows = document.querySelectorAll<HTMLElement>("[data-attr-sub]");

  function debounce(fn: () => void, ms: number): () => void {
    let timer: ReturnType<typeof setTimeout>;

    return () => {
      clearTimeout(timer);
      timer = setTimeout(fn, ms);
    };
  }

  function readOptions(): ReducerConfiguration {
    const config = { ...DEFAULT_CONFIG };
    toggleInputs.forEach((input) => {
      const key = input.dataset.key as keyof ReducerConfiguration;
      if (typeof config[key] === "boolean") {
        (config as Record<string, unknown>)[key] = input.checked;
      }
    });

    return config;
  }

  function updateStats(inputLen: number, outputLen: number): void {
    inputCharsEl.textContent = `${inputLen.toLocaleString()} chars`;
    tokenCountEl.textContent = `~${Math.round(outputLen / 4).toLocaleString()} tokens`;

    const reduction = inputLen > 0 ? Math.round((1 - outputLen / inputLen) * 100) : 0;
    if (reduction > 0) {
      reductionEl.textContent = `−${reduction}%`;
      reductionEl.style.display = "";
    } else {
      reductionEl.style.display = "none";
    }
  }

  function syncStripAllAttrs(): void {
    const stripping = stripAllInput.checked;
    attrKeepRows.forEach((row) => {
      row.classList.toggle("disabled", stripping);
      const input = row.querySelector<HTMLInputElement>("input");
      if (input) input.disabled = stripping;
    });
  }

  const process = debounce(() => {
    const input = inputEl.value;
    const output = input.trim() ? reduceHtml(input, readOptions()) : "";
    outputEl.textContent = output;
    updateStats(input.length, output.length);
  }, 150);

  inputEl.addEventListener("input", process);

  controlsToggle.addEventListener("click", () => {
    const expanded = controlsBody.classList.toggle("collapsed") === false;
    controlsToggle.setAttribute("aria-expanded", String(expanded));
  });

  toggleInputs.forEach((input) => {
    input.addEventListener("change", () => {
      if (input.dataset.key === "stripAllAttrs") syncStripAllAttrs();
      process();
    });
  });

  clearBtn.addEventListener("click", () => {
    inputEl.value = "";
    outputEl.textContent = "";
    updateStats(0, 0);
  });

  copyBtn.addEventListener("click", async () => {
    const text = outputEl.textContent ?? "";
    if (!text) return;

    try {
      await navigator.clipboard.writeText(text);
      const original = copyBtn.innerHTML;
      copyBtn.innerHTML = "copied!";
      setTimeout(() => {
        copyBtn.innerHTML = original;
      }, 1500);
    } catch {
      // Clipboard unavailable (non-secure context)
    }
  });

  resetBtn.addEventListener("click", () => {
    toggleInputs.forEach((input) => {
      const key = input.dataset.key as keyof ReducerConfiguration;
      if (typeof DEFAULT_CONFIG[key] === "boolean") {
        input.checked = DEFAULT_CONFIG[key] as boolean;
        input.disabled = false;
      }
    });
    syncStripAllAttrs();
    process();
  });

  syncStripAllAttrs();
  updateStats(0, 0);
</script>
